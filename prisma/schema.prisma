// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String     @id @default(cuid())
  name         String
  company      String?
  type         String     // e.g. "Ativo", "Negociação", "Proposta", "Lead", "Inativo"
  monthlyValue Float
  instagram    String?    // Link ou @ do Instagram
  tasks        Task[]
  proposals    Proposal[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  events       Event[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  priority    String   // "Alta", "Média", "Baixa"
  status      String   // "Pendente", "Concluída"
  date        DateTime
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Proposal {
  id        String   @id @default(cuid())
  title     String
  status    String   // "Aprovada", "Enviada", "Recusada"
  value     Float
  link      String?  // PDF URL or External Link
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  color     String   @default("bg-cyan-500")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  type        String   // "Reunião", "Projeto", "Lembrete"
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id          String   @id @default("global")
  agencyName  String   @default("Veris Digital")
  theme       String   @default("dark")
  updatedAt   DateTime @updatedAt
}
